<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:contentDescription="@string/back"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/coffee13" />

    <!-- Semi-transparent overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:contentDescription="@string/back"
                    android:id="@+id/backBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/category_bg_selected"
                    android:padding="10dp"
                    android:src="@drawable/back_icon"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/checkout"
                    android:textColor="@color/creamBackground"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Delivery Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:background="@drawable/brown_2_full_corner"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/deliveryInfo"
                    android:textColor="@color/creamBackground"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/fullName"
                    android:textColor="@color/creamBackground"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:autofillHints=""
                    android:id="@+id/nameInput"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:background="@drawable/brown_gradient_bg"
                    android:hint="@string/enterName"
                    android:inputType="textPersonName"
                    android:padding="12dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/lightBrown"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/creamBackground"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:autofillHints=""
                    android:id="@+id/phoneInput"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:background="@drawable/brown_gradient_bg"
                    android:hint="@string/PhoneNo"
                    android:inputType="phone"
                    android:padding="12dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/lightBrown"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/creamBackground"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:autofillHints=""
                    android:id="@+id/addressInput"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/brown_gradient_bg"
                    android:gravity="top"
                    android:hint="@string/delAdd"
                    android:inputType="textMultiLine"
                    android:padding="12dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/lightBrown"
                    android:textSize="14sp" />
            </LinearLayout>
            <!-- Payment Method -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/brown_2_full_corner"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Payment Method"
                    android:textColor="@color/creamBackground"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/paymentMethodGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/radioCash"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="Cash on Delivery"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:padding="8dp" />

                    <RadioButton
                        android:id="@+id/radioCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Credit/Debit Card"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:padding="8dp" />
                </RadioGroup>

                <!-- Card Details (Hidden by default) -->
                <LinearLayout
                    android:id="@+id/cardDetailsLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Card Number"
                        android:textColor="@color/creamBackground"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/cardNumberInput"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/brown_gradient_bg"
                        android:hint="1234 5678 9012 3456"
                        android:inputType="number"
                        android:maxLength="16"
                        android:padding="12dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/lightBrown"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cardholder Name"
                        android:textColor="@color/creamBackground"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/cardNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/brown_gradient_bg"
                        android:hint="Name on card"
                        android:inputType="textCapWords"
                        android:padding="12dp"
                        android:textColor="@color/creamBackground"
                        android:textColorHint="@color/lightBrown"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Expiry Date"
                                android:textColor="@color/creamBackground"
                                android:textSize="12sp"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/expiryInput"
                                android:layout_width="match_parent"
                                android:layout_height="45dp"
                                android:background="@drawable/brown_gradient_bg"
                                android:hint="MM/YY"
                                android:inputType="number"
                                android:maxLength="5"
                                android:padding="12dp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/lightBrown"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CVV"
                                android:textColor="@color/creamBackground"
                                android:textSize="12sp"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/cvvInput"
                                android:layout_width="match_parent"
                                android:layout_height="45dp"
                                android:background="@drawable/brown_gradient_bg"
                                android:hint="123"
                                android:inputType="numberPassword"
                                android:maxLength="3"
                                android:padding="12dp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/lightBrown"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>


            <!-- Order Summary -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:background="@drawable/brown_2_full_corner"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/OrderSum"
                    android:textColor="@color/creamBackground"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/Subtotal"
                        android:textColor="@color/lightBrown"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/subtotalText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/startPrice"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/delFee"
                        android:textColor="@color/lightBrown"
                        android:textSize="14sp" />

                    <!-- Dynamic delivery fee from Kotlin -->
                    <TextView
                        android:id="@+id/deliveryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/startPrice"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/lightBrown"
                    android:layout_marginVertical="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/total"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/totalText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/startPrice"
                        android:textColor="@color/orange"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/placeOrderBtn"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_margin="16dp"
                android:background="@drawable/orange_corner"
                android:text="@string/placeOrder"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:contentDescription="@string/back"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/welcome" />

    <!-- Dark Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000" />

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">
        

        <!-- Welcome Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome"
            android:textColor="@color/creamBackground"
            android:textSize="25sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loginCont"
            android:textColor="@color/lightBrown"
            android:textSize="15sp"
            android:layout_marginBottom="30dp" />

        <!-- Username Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/username"
            android:textColor="@color/creamBackground"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/usernameInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/brown_2_full_corner"
            android:hint="@string/enterUser"
            android:inputType="text"
            android:textSize="14dp"
            android:padding="12dp"
            android:textColor="@color/creamBackground"
            android:textColorHint="@color/darkBeige"
            android:layout_marginBottom="15dp" />

        <!-- Password Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/password"
            android:textColor="@color/creamBackground"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp">

            <EditText
                android:autofillHints=""
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:textSize="14dp"
                android:background="@drawable/brown_2_full_corner"
                android:hint="@string/enterPass"
                android:inputType="textPassword"
                android:padding="12dp"
                android:paddingEnd="45dp"
                android:textColor="@color/creamBackground"
                android:textColorHint="@color/darkBeige" />

            <ImageView
                android:contentDescription="@string/back"
                android:id="@+id/passwordToggle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:src="@drawable/eye_off_icon"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="2dp"
                app:tint="@color/lightBrown" />

        </RelativeLayout>

        <!-- Forgot Password -->
        <TextView
            android:id="@+id/forgotPasswordText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/forget"
            android:textColor="@color/darkBeige"
            android:textSize="11sp"
            android:gravity="end"
            android:layout_marginBottom="30dp"
            android:clickable="true"
            android:focusable="true" />


        <!-- Login Button -->
        <Button
            android:id="@+id/loginButton"
            android:layout_width="120dp"
            android:layout_height="55dp"
            android:background="@drawable/orange_corner"
            android:text="@string/login"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- Sign Up Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don't have an account? "
                android:textColor="@color/creamBackground"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/signUpText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/signup"
                android:textColor="@color/darkBeige"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Skip Button -->
        <TextView
            android:id="@+id/skipText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/skipNow"
            android:textColor="@color/creamBackground"
            android:textSize="10sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>

</FrameLayout>
<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:contentDescription="@string/back"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/coffee14" />

    <!-- Dark Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000" />

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">


        <!-- Welcome Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textColor="@color/creamBackground"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign up to get started"
            android:textColor="@color/lightBrown"
            android:textSize="15sp"
            android:layout_marginBottom="30dp" />

        <!-- Full Name Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Username"
            android:textColor="@color/creamBackground"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/nameInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/brown_2_full_corner"
            android:hint="Enter your username"
            android:textSize="14dp"
            android:inputType="textPersonName"
            android:padding="12dp"
            android:textColor="@color/creamBackground"
            android:textColorHint="@color/creamBackground"
            android:layout_marginBottom="16dp" />

        <!-- Email Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="@color/creamBackground"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/emailInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/brown_2_full_corner"
            android:hint="Enter your email"
            android:textSize="14dp"
            android:inputType="textEmailAddress"
            android:padding="12dp"
            android:textColor="@color/creamBackground"
            android:textColorHint="@color/creamBackground"
            android:layout_marginBottom="16dp" />

        <!-- Phone Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:textColor="@color/creamBackground"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/phoneInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/brown_2_full_corner"
            android:hint="Enter your phone number"
            android:inputType="phone"
            android:padding="12dp"
            android:textSize="14dp"
            android:textColor="@color/creamBackground"
            android:textColorHint="@color/creamBackground"
            android:layout_marginBottom="16dp" />

        <!-- Password Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="@color/creamBackground"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/brown_2_full_corner"
                android:textSize="14dp"
                android:hint="Create a password"
                android:inputType="textPassword"
                android:padding="12dp"
                android:paddingEnd="45dp"
                android:textColor="@color/creamBackground"
                android:textColorHint="@color/creamBackground" />

            <ImageView
                android:contentDescription="@string/back"
                android:id="@+id/passwordToggle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:src="@drawable/eye_off_icon"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="2dp"
                app:tint="@color/lightBrown" />

        </RelativeLayout>

        <!-- Confirm Password Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirm Password"
            android:textColor="@color/creamBackground"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="30dp">

            <EditText
                android:id="@+id/confirmPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/brown_2_full_corner"
                android:hint="Confirm your password"
                android:inputType="textPassword"
                android:padding="12dp"
                android:paddingEnd="45dp"
                android:textColor="@color/creamBackground"
                android:textColorHint="@color/creamBackground"
                android:textSize="14dp" />

            <ImageView
                android:id="@+id/confirmPasswordToggle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:src="@drawable/eye_off_icon"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="2dp"
                app:tint="@color/lightBrown" />

        </RelativeLayout>

        <!-- Sign Up Button -->
        <Button
            android:id="@+id/signUpButton"
            android:layout_width="140dp"
            android:layout_height="55dp"
            android:background="@drawable/orange_corner"
            android:text="Sign Up"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- Login Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="@color/creamBackground"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/loginText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Login"
                android:textColor="@color/darkBeige"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>

</FrameLayout>